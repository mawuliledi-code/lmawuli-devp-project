<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../includes/head', { title: 'New Cookie | CraveLab' }) %>
  <link rel="stylesheet" href="/styles/main.css">
</head>

<body>

  <header class="site-header">
    <div class="container">
      <h1 class="logo">
        <a href="/">CraveLab <span aria-hidden="true">🍪🌿</span></a>
      </h1>

      <nav class="main-nav" aria-label="Main navigation">
        <ul>
          <li><a href="/" class="active">Shop</a></li>
          <li><a href="/blog">Blog</a></li>
          <li><a href="/discover">Discover</a></li>
          <li><a href="/contact">Contact</a></li>
        </ul>
      </nav>
    </div>
  </header>


  <section class="hero-banner">
    <div class="container">
      <h2>Create a New CraveLab Cookie 🍪</h2>
      <p>Design your favorite flavor and add it to the CraveLab collection.</p>
    </div>
  </section>

  <main class="container">

    <section class="form-wrapper">


      <aside class="form-left">
        <span class="form-emoji">🍪🍓 🍪🍌 </span>
        <h3>Design Your Cookie</h3>
        <p>Fill in and bring your creation to life!</p>

        <ul class="form-tips">
          <li>Use a catchy cookie name</li>
          <li>Pick a unique flavor and taste</li>
          <li>Happy about your design!</li>
        </ul>
      </aside>

      <div class="form-right">
        <h2>New Cookie Details</h2>
        <p class="form-desc">
          Fill in the form below to add your style to the menu.
        </p>

        <form action="/cookies" method="POST">

          <div class="input-group">
            <label for="name">Cookie Name</label>
            <input 
              type="text" 
              id="name" 
              name="name" 
              placeholder="e.g. Peanut Chocolate Chip" 
              required 
            />
          </div>

          <div class="input-group">
            <label for="design">Description</label>
            <input 
              type="text" 
              id="design" 
              name="design" 
              placeholder="e.g. A rich chocolate cookie with peanut crunch" 
              required 
            />
          </div>

          <div class="input-group">
            <label for="date">Date</label>
            <input 
              type="date" 
              id="date" 
              name="date" 
              required 
            />
          </div>

          <div class="form-actions">
            <button type="submit">Happy To Go!</button>
            <a href="/cookies" class="back-link">← Back to Cookies</a>
          </div>

        </form>
      </div>

    </section>

  </main>

  <!-- FOOTER -->
  <footer class="site-footer">
    <p>
      Made with Love 🥰🫶🍪 by <strong>CraveLab</strong> &copy; <%= new Date().getFullYear() %>
    </p>
  </footer>

</body>
</html>