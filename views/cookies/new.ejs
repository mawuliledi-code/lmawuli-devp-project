<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../includes/head', {title: 'New Cookie | CraveLab'}) %>
  <link rel="stylesheet" href="/styles/main.css">
</head>

<body>

  <header>
    <h1>CraveLab 🍪</h1>
    <nav>
      <a href="/">SHOP</a>
      <a href="/blog">BLOG</a>
      <a href="/discover">DISCOVER</a>
      <a href="/contact">CONTACT</a>
    </nav>
  </header>

  <main>

    <section class="form-wrapper">

      <div class="form-left">
        <span class="form-emoji">🍪</span>
        <h2>Design Your New CraveLab</h2>
        <p>Design your Favarite flavour. Fill in the details and get ready to Enjoy!</p>
        <ul class="form-tips">
          <li> Use a catchy cookie name</li>
          <li>Pick a unique peanut type</li>
        </ul>
      </div>

      <div class="form-right">
        <form action="/cookies" method="POST">

          <div class="input-group">
            <label for="name">🍪 Cookie Name</label>
            <input 
              type="text" 
              id="name" 
              name="name" 
              placeholder="e.g. Peanut Chocolate Chip" 
              required 
            />
          </div>

          <div class="input-group">
            <label for="peanut">🥜 Peanut</label>
            <input 
              type="text" 
              id="slug" 
              name="peanut" 
              placeholder="e.g. New Cookies Just Dropped!" 
              required 
            />
          </div>

          <div class="input-group">
            <label for="date">Date</label>
            <input 
              type="date" 
              id="date" 
              name="date" 
              required 
            />
          </div>

          <button type="submit">MAKE THIS HAPPEN!</button>
          <a href="/news" class="back-link">← Back to Design</a>

        </form>
      </div>

    </section>

  </main>

  <footer>
    <p>Made with sweet 🍪 by <strong>CraveLab</strong> &copy; <%= new Date().getFullYear() %></p>
  </footer>

</body>
</html>
